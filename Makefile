CXX = g++
CXXFLAGS = -std=c++17 -Wall -Iinclude
LDFLAGS = -lsfml-graphics -lsfml-window -lsfml-system

TARGET = app
LIB = libwave.a

# ????????? ????? ????????? ??????????
APP_OBJS = main.o src/ui/UIPanel.o

all: $(LIB) $(TARGET)

# ??????? ??????????? ?????????? ?????? ? ???????
$(LIB): src/physics/Vector3.o src/physics/Wave.o src/render/WaveRenderer.o
	ar rcs $@ $^

# ???????? ???????? ?????????
$(TARGET): $(APP_OBJS) $(LIB)
	$(CXX) $(APP_OBJS) -o $@ -L. $(LDFLAGS) -lwave

# ?????????? .cpp ? .o (??? ?????? ? ????? ???????)
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

# ?????????? ?????? ?? ???????????? (????? make ????????? ??????? ??????????)
src/physics/%.o: src/physics/%.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

src/render/%.o: src/render/%.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

run: $(TARGET)
	./$(TARGET)

clean:
	rm -f src/physics/*.o src/render/*.o main.o UIPanel.o $(LIB) $(TARGET)

.PHONY: all run clean